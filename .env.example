# OpenRouter Configuration
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here
HELIOS_MODEL=qwen/qwen-2.5-coder-32b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Fallback Configuration
LLM_TIMEOUT_SECONDS=15
MAX_LLM_RETRIES=3

# Rust Core Configuration
RUST_CORE_HOST=localhost
RUST_CORE_PORT=50051

# Security
SANITIZE_SENSITIVE_DATA=true

# Allowed Targets for Pentesting (comma-separated)
ALLOWED_TARGETS=127.0.0.1,localhost,192.168.1.0/24
